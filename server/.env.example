# Copia este archivo como .env y completa los valores.
# NUNCA subas .env a Git (ya está en .gitignore).

PORT=3001

# Destino de los avisos (registro y contacto). Por defecto el código usa bewashsas1@gmail.com si no defines EMAIL_TO.
# EMAIL_TO=bewashsas1@gmail.com
# Cuenta Gmail que ENVÍA (debe coincidir con GMAIL_APP_PASSWORD). Lo habitual es la misma bewashsas1@gmail.com:
GMAIL_USER=bewashsas1@gmail.com
# Contraseña de aplicación (no la contraseña normal de la cuenta):
# https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Clave para ver los registros en /api/admin/registros?key=...
ADMIN_KEY=tu_clave_secreta_admin_123

# --- Panel admin (login con correo + contraseña, solo 2 correos autorizados en código) ---
# Secreto para firmar sesiones y enlaces de recuperación (mín. 16 caracteres; usa un valor largo y aleatorio).
JWT_SECRET=cambia_esto_por_una_cadena_larga_y_aleatoria_minimo_16

# URL pública del sitio (para enlaces en correos de recuperación). En Vercel suele bastar con dejarlo vacío.
# PUBLIC_SITE_URL=https://tu-dominio.vercel.app

# Enlace del botón «Bono BeParking» en el correo al cliente (opcional). Por defecto: https://www.beparking.com.co/Register
# BE_PARKING_URL=https://www.beparking.com.co/Register

# En Vercel: contraseñas admin en /tmp se pierden al reiniciar. Crea un Blob Store en el proyecto (Storage → Blob)
# para que exista BLOB_READ_WRITE_TOKEN y las contraseñas (p. ej. tras «restablecer») persistan.
# BLOB_READ_WRITE_TOKEN se añade automáticamente al enlazar el store.

# Contraseña inicial: se guarda con hash en server/data/admin_auth.json (local) o /tmp (Vercel).
# Tras el primer arranque puedes quitar estas variables y usar solo "Olvidé mi contraseña".
# Opción A — misma contraseña temporal para ambos administradores:
ADMIN_INITIAL_PASSWORD=cambia_esta_contrasena_temporal
# Opción B — una por cuenta (si están definidas, tienen prioridad sobre ADMIN_INITIAL_PASSWORD para esa cuenta):
# ADMIN_BOOTSTRAP_BEWASHSAS1=...
# ADMIN_BOOTSTRAP_JUANDABALLESTEROS014=...
